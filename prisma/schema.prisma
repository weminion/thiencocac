generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// User point balance and unlocked features
model Point {
  id             String        @id @default(cuid())
  userId         String        @unique
  balance        Int           @default(0)
  totalEarned    Int           @default(0)
  streak         Int           @default(0)
  longestStreak  Int           @default(0)
  lastCheckIn    DateTime?
  extraChart     Boolean       @default(false)
  deepLuanGiai   Boolean       @default(false)
  detailedHours  Boolean       @default(false)
  weddingDate    Boolean       @default(false)
  consultVoucher Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  rituals        DailyRitual[]
  log            PointLog[]
}

/// Completed ritual record — idempotent per (userId, date, kind)
model DailyRitual {
  id        String     @id @default(cuid())
  userId    String
  date      DateTime   @db.Date
  kind      RitualKind
  reward    Int
  label     String
  createdAt DateTime   @default(now())
  point     Point      @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, date, kind])
  @@index([userId, date])
}

/// Point earn/spend history
model PointLog {
  id        String   @id @default(cuid())
  userId    String
  dateLabel String
  action    String
  amount    Int
  createdAt DateTime @default(now())
  point     Point    @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

enum RitualKind {
  checkin
  incense
  meditation
  fasting
}

enum UnlockKey {
  extraChart
  deepLuanGiai
  detailedHours
  weddingDate
  consultVoucher
}
